{
	"$schema": "https://opencode.ai/config.json",
	"mcp": {
		"playwright": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"@playwright/mcp@latest"
			],
			"enabled": true
		},
		"context7": {
			"type": "remote",
			"url": "https://mcp.context7.com/mcp",
			"enabled": true
		}
	},
	"permission": {
		"bash": "ask"
	},
	"plugin": [
		"@mohak34/opencode-notifier@latest",
		"./plugins/rtk.ts"
	],
	"agent": {
		"explore": {
			"model": "opencode-go/minimax-m2.7"
		}
	}
}
